> !="Glostrup" & FormerMunicipality!="Herlev" & FormerMunicipality!="Hvidovre" & FormerMunicipality!="HøjeTaastrup" & FormerMunicipality!="Torslunde-Is
> høj" & FormerMunicipality!="Ledøje-Smørum" & FormerMunicipality!="Lyngby-Taarbæk" & FormerMunicipality!="Rødovre" & FormerMunicipality!="Søllerød" & 
> FormerMunicipality!="Tårnby" & FormerMunicipality!="Vallensbæk" & FormerMunicipality!="Værløse"
  9. collapse(sum) TEMP_I-TEMP_II, by(year) 
 10. gen FormerMunicipality="Københavns"
 11. save "./TEMP/Copenhagen_`VVV'", replace 
 12. *---------------------------------
. *---------------------------------
. use "./TEMP/`VVV'", clear  
 13. drop if FormerMunicipality !="Ærøskøbing(-2005/2006)" & FormerMunicipality!="Marstal" & FormerMunicipality!="Ærø(2005/2006-)" 
 14. collapse(sum) TEMP_I-TEMP_II, by(year) 
 15. gen FormerMunicipality="Ærøskøbing" 
 16. save "./TEMP/Aeroskobing_`VVV'", replace 
 17. *--------------------------------------------------
. *--------------------------------------------------
. * Append the merged data to the rest of the dataset
. *--------------------------------------------------
. use "./TEMP/`VVV'", clear
 18. *-----------remove the municipalities included in Copenhagen county---------
. drop if FormerMunicipality=="Copenhagen"
 19. drop if FormerMunicipality=="Frederiksberg" 
 20. drop if FormerMunicipality=="Albertslund" 
 21. drop if FormerMunicipality=="Ballerup"
 22. drop if FormerMunicipality=="Brøndby"
 23. drop if FormerMunicipality=="Dragør"
 24. drop if FormerMunicipality=="Gentofte"
 25. drop if FormerMunicipality=="Gladsaxe"
 26. drop if FormerMunicipality=="Glostrup"
 27. drop if FormerMunicipality=="Herlev"
 28. drop if FormerMunicipality=="Hvidovre"
 29. drop if FormerMunicipality=="HøjeTaastrup"
 30. drop if FormerMunicipality=="Torslunde-Ishøj"
 31. drop if FormerMunicipality=="Ledøje-Smørum"
 32. drop if FormerMunicipality=="Lyngby-Taarbæk"
 33. drop if FormerMunicipality=="Rødovre"
 34. drop if FormerMunicipality=="Søllerød"
 35. drop if FormerMunicipality=="Tårnby"
 36. drop if FormerMunicipality=="Vallensbæk"
 37. drop if FormerMunicipality=="Værløse"
 38. *remove the former disaggregated municipalities in Ærøskøbing/Marstal 
. drop if FormerMunicipality=="Ærøskøbing(-2005/2006)"
 39. drop if FormerMunicipality=="Marstal" 
 40. drop if FormerMunicipality=="Ærø(2005/2006-)" 
 41. *remove the disaggregated municipalities in Bornholm
. drop if FormerMunicipality=="Allinge-Gudhjem"
 42. drop if FormerMunicipality=="Hasle"
 43. drop if FormerMunicipality=="Nexø"
 44. drop if FormerMunicipality=="Rønne"
 45. drop if FormerMunicipality=="Aakrikreby"
 46. *----------------------------------
. append using "./TEMP/Copenhagen_`VVV'"
 47. append using "./TEMP/Aeroskobing_`VVV'"
 48. *----------------------------------
. egen MUN_ID=group(FormerMunicipality)
 49. sum MUN_ID
 50. drop TEMP_I TEMP_II
 51. save "./TEMP/`VVV'", replace 
 52. }
